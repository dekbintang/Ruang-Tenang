<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android">
    <scale
        android:fromXScale="1.0" android:toXScale="1.06"
        android:fromYScale="1.0" android:toYScale="1.06"
        android:pivotX="50%" android:pivotY="50%"
        android:duration="900" android:repeatCount="infinite"
        android:repeatMode="reverse" android:interpolator="@android:anim/accelerate_decelerate_interpolator" />
    <rotate
        android:fromDegrees="-1" android:toDegrees="1.5"
        android:pivotX="50%" android:pivotY="50%"
        android:duration="900" android:repeatCount="infinite"
        android:repeatMode="reverse" />
</set>