<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android">
    <scale
        android:fromXScale="0.95" android:toXScale="1.12"
        android:fromYScale="0.95" android:toYScale="1.12"
        android:pivotX="50%" android:pivotY="50%"
        android:duration="400" android:repeatCount="infinite"
        android:repeatMode="reverse" android:interpolator="@android:anim/accelerate_decelerate_interpolator" />
    <rotate
        android:fromDegrees="-3" android:toDegrees="3"
        android:pivotX="50%" android:pivotY="50%"
        android:duration="300" android:repeatCount="infinite"
        android:repeatMode="reverse" />
</set>