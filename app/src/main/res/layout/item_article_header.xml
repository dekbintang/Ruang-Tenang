<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Section label -->
    <TextView
        android:id="@+id/tv_section_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        android:text="Featured Articles"
        android:textColor="#1e293b"
        android:textSize="17sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    <!-- HorizontalScrollView untuk featured cards -->
    <HorizontalScrollView
        android:id="@+id/hsv_featured"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp">

        <!-- Featured cards will be added programmatically -->
        <LinearLayout
            android:id="@+id/ll_featured_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />

    </HorizontalScrollView>

</LinearLayout>
