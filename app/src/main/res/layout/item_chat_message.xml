<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp">

    <!-- Pesan Diterima (dari Dokter) — rata kiri -->
    <LinearLayout
        android:id="@+id/layout_received"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chat_received"
            android:padding="14dp"
            android:maxWidth="280dp">

            <TextView
                android:id="@+id/tv_message_received"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pesan dokter"
                android:textColor="@color/textPrimary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.35" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_time_received"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="8dp"
            android:text="10:00"
            android:textColor="@color/textSecondary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Pesan Terkirim (dari Pengguna) — rata kanan -->
    <LinearLayout
        android:id="@+id/layout_sent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chat_sent"
            android:padding="14dp"
            android:maxWidth="280dp">

            <TextView
                android:id="@+id/tv_message_sent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pesan pengguna"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.35" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_time_sent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:layout_gravity="end"
            android:text="10:00"
            android:textColor="@color/textSecondary"
            android:textSize="11sp" />
    </LinearLayout>

</FrameLayout>
