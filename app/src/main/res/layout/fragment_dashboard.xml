<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  HEADER                                            -->
        <!-- ═══════════════════════════════════════════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashboard_header"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="48dp"
                android:paddingBottom="72dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Greeting kiri -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_greeting_en"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Good Morning ☀️"
                            android:textColor="#FFFFFF"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.01" />

                        <TextView
                            android:id="@+id/tv_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="You are doing great today!"
                            android:textColor="#E0EAFF"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- Streak pill + Avatar kanan -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <!-- Profile Avatar -->
                        <FrameLayout
                            android:id="@+id/btn_profile"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:background="@drawable/bg_avatar_ring">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_profile"
                                app:tint="#FFFFFF" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- KONTEN UTAMA                                        -->
        <!-- ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="-36dp"
            android:paddingHorizontal="20dp"
            android:paddingBottom="40dp">

            <!-- ─── Bagian Pilih Mood ─────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How are you feeling?"
                        android:textColor="@color/textPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Bagaimana perasaanmu hari ini?"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        android:textStyle="italic" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:scrollbars="none"
                        android:clipToPadding="false"
                        android:paddingHorizontal="4dp">

                        <LinearLayout
                            android:id="@+id/layout_emojis"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <!-- Senang -->
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="8dp">
                                <ImageButton android:id="@+id/btn_emoji_happy" android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_mood_happy" android:src="@drawable/ic_mood_happy" android:scaleType="centerInside" android:padding="12dp" android:stateListAnimator="@animator/card_lift" app:tint="#FFFFFF" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Senang" android:textColor="@color/textSecondary" android:textSize="10sp" android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Tenang -->
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="8dp">
                                <ImageButton android:id="@+id/btn_emoji_calm" android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_mood_calm" android:src="@drawable/ic_mood_calm" android:scaleType="centerInside" android:padding="12dp" android:stateListAnimator="@animator/card_lift" app:tint="#FFFFFF" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Tenang" android:textColor="@color/textSecondary" android:textSize="10sp" android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Biasa -->
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="8dp">
                                <ImageButton android:id="@+id/btn_emoji_neutral" android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_mood_neutral" android:src="@drawable/ic_mood_neutral" android:scaleType="centerInside" android:padding="12dp" android:stateListAnimator="@animator/card_lift" app:tint="#FFFFFF" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Biasa" android:textColor="@color/textSecondary" android:textSize="10sp" android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Sedih -->
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="8dp">
                                <ImageButton android:id="@+id/btn_emoji_sad" android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_mood_sad" android:src="@drawable/ic_mood_sad" android:scaleType="centerInside" android:padding="12dp" android:stateListAnimator="@animator/card_lift" app:tint="#FFFFFF" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Sedih" android:textColor="@color/textSecondary" android:textSize="10sp" android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Cemas -->
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="8dp">
                                <ImageButton android:id="@+id/btn_emoji_anxious" android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_mood_anxious" android:src="@drawable/ic_mood_anxious" android:scaleType="centerInside" android:padding="12dp" android:stateListAnimator="@animator/card_lift" app:tint="#FFFFFF" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Cemas" android:textColor="@color/textSecondary" android:textSize="10sp" android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Marah -->
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="8dp">
                                <ImageButton android:id="@+id/btn_emoji_angry" android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_mood_angry" android:src="@drawable/ic_mood_angry" android:scaleType="centerInside" android:padding="12dp" android:stateListAnimator="@animator/card_lift" app:tint="#FFFFFF" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Marah" android:textColor="@color/textSecondary" android:textSize="10sp" android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Malu -->
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="8dp">
                                <ImageButton android:id="@+id/btn_emoji_shy" android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_mood_shy" android:src="@drawable/ic_mood_shy" android:scaleType="centerInside" android:padding="12dp" android:stateListAnimator="@animator/card_lift" app:tint="#FFFFFF" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Malu" android:textColor="@color/textSecondary" android:textSize="10sp" android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Takut -->
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="8dp">
                                <ImageButton android:id="@+id/btn_emoji_scared" android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_mood_scared" android:src="@drawable/ic_mood_scared" android:scaleType="centerInside" android:padding="12dp" android:stateListAnimator="@animator/card_lift" app:tint="#FFFFFF" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Takut" android:textColor="@color/textSecondary" android:textSize="10sp" android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Malas -->
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="8dp">
                                <ImageButton android:id="@+id/btn_emoji_lazy" android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_mood_lazy" android:src="@drawable/ic_mood_lazy" android:scaleType="centerInside" android:padding="12dp" android:stateListAnimator="@animator/card_lift" app:tint="#FFFFFF" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Malas" android:textColor="@color/textSecondary" android:textSize="10sp" android:textStyle="bold" />
                            </LinearLayout>

                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── Emotion Meter ──────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:stateListAnimator="@animator/card_lift"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <FrameLayout
                        android:layout_width="90dp"
                        android:layout_height="90dp">

                        <ProgressBar
                            android:id="@+id/progress_emotion"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="90dp"
                            android:layout_height="90dp"
                            android:max="100"
                            android:progress="75"
                            android:progressDrawable="@drawable/circular_progress"
                            android:rotation="-90" />

                        <TextView
                            android:id="@+id/tv_progress_percentage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="75%"
                            android:textColor="@color/primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Emotion Meter"
                            android:textColor="@color/textPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Meteran Emosi"
                            android:textColor="@color/primary"
                            android:textSize="12sp"
                            android:textStyle="italic" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="You've been feeling mostly"
                            android:textColor="@color/textSecondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tv_emotion_result"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="😄 Happy this week."
                            android:textColor="#F59E0B"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_emotion_encouragement"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Keep it up! 💪"
                            android:textColor="@color/textSecondary"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── Quick Actions ───────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick Actions"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Aksi Cepat"
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp"
                    android:textStyle="italic" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Tulis Jurnal -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_new_journal"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/card_lift"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp"
                    app:strokeWidth="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_card_journal"
                        android:foreground="?attr/selectableItemBackground">

                        <View android:layout_width="72dp" android:layout_height="72dp" android:layout_gravity="top|end" android:layout_marginTop="-16dp" android:layout_marginEnd="-16dp" android:background="@drawable/bg_icon_glass" />

                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="bottom" android:orientation="vertical" android:padding="16dp">
                            <ImageView android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_glass" android:padding="10dp" android:scaleType="centerInside" android:src="@drawable/ic_action_journal" app:tint="#FFFFFF" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Write" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tulis Jurnal" android:textColor="#B0C4FF" android:textSize="12sp" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Tenangkan Diri -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_quick_calm"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/card_lift"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp"
                    app:strokeWidth="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_card_calm"
                        android:foreground="?attr/selectableItemBackground">

                        <View android:layout_width="72dp" android:layout_height="72dp" android:layout_gravity="top|end" android:layout_marginTop="-16dp" android:layout_marginEnd="-16dp" android:background="@drawable/bg_icon_glass" />

                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="bottom" android:orientation="vertical" android:padding="16dp">
                            <ImageView android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_glass" android:padding="10dp" android:scaleType="centerInside" android:src="@drawable/ic_action_calm" app:tint="#FFFFFF" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Breathe" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tenangkan Diri" android:textColor="#A0E0D8" android:textSize="12sp" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ─── Jurnal Terakhir ────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="vertical">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jurnal Terakhir" android:textColor="@color/textPrimary" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Lanjutkan tulisanmu" android:textColor="@color/textSecondary" android:textSize="12sp" android:textStyle="italic" />
                    </LinearLayout>
                    <TextView android:id="@+id/tv_see_all_journals" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_chip" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" android:paddingHorizontal="12dp" android:paddingVertical="6dp" android:text="Lihat Semua" android:textColor="@color/primary" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_dashboard_journals"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginHorizontal="-20dp"
                    android:paddingHorizontal="20dp"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_journal" />

                <TextView
                    android:id="@+id/tv_empty_journals"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Belum ada jurnal. Mulai tulis hari ini!"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:textStyle="italic"
                    android:gravity="center"
                    android:visibility="gone" />
            </LinearLayout>



        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>