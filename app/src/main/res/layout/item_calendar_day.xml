<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_day_cell"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="3dp"
    android:foreground="?attr/selectableItemBackground">

    <!--
        Container lingkaran: background akan diset secara programatik
        bg_calendar_today / bg_calendar_has_journal / transparent
    -->
    <FrameLayout
        android:id="@+id/frame_day_circle"
        android:layout_width="42dp"
        android:layout_height="42dp">

        <!-- Ikon mood (jika ada jurnal di hari itu) -->
        <ImageView
            android:id="@+id/iv_day_mood"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- Nomor hari di bawah mood icon -->
        <TextView
            android:id="@+id/tv_day_number"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="1"
            android:textColor="#334155"
            android:textSize="13sp"
            android:textStyle="normal"
            android:fontFamily="sans-serif-medium"
            android:visibility="visible" />

    </FrameLayout>

    <!-- Dot indikator jurnal di bawah angka (hanya muncul jika ada jurnal) -->
    <View
        android:id="@+id/view_journal_dot"
        android:layout_width="5dp"
        android:layout_height="5dp"
        android:layout_marginTop="2dp"
        android:background="#1E3A8A"
        android:visibility="gone" />

    <!-- Placeholder dot transparan supaya layout tidak bergeser -->
    <View
        android:id="@+id/view_mood_placeholder"
        android:layout_width="5dp"
        android:layout_height="5dp"
        android:layout_marginTop="2dp"
        android:background="@android:color/transparent"
        android:visibility="visible" />

</LinearLayout>
