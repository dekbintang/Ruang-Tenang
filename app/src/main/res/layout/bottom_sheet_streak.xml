<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="28dp"
    android:paddingTop="16dp"
    android:paddingBottom="28dp">

    <!-- Handle drag -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@drawable/bg_drag_handle"
        android:layout_marginBottom="28dp" />

    <!-- Big Flame Icon with Background -->
    <FrameLayout
        android:id="@+id/flame_container"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:background="@drawable/bg_profile_circle"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/tv_sheet_flame"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🔥"
            android:textSize="48sp" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_streak_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Streak 5 Hari!"
        android:textColor="@color/textPrimary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_streak_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Luar biasa! Apinya sedang menyala terang."
        android:textColor="@color/textSecondary"
        android:textSize="14sp"
        android:textAlignment="center"
        android:layout_marginBottom="28dp"
        android:lineSpacingExtra="4dp" />

    <!-- Streak Level Indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <!-- Level 1: 1-3 hari -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_level_1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="🔥"
                android:textSize="18sp"
                android:background="@drawable/bg_stat_item"
                android:backgroundTint="#FFF7ED" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="1+"
                android:textColor="@color/textSecondary"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Level 2: 4-6 hari -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_level_2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="🔥"
                android:textSize="18sp"
                android:background="@drawable/bg_stat_item"
                android:backgroundTint="#F1F5F9" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="4+"
                android:textColor="@color/textSecondary"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Level 3: 7-13 hari -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_level_3"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="🌟"
                android:textSize="18sp"
                android:background="@drawable/bg_stat_item"
                android:backgroundTint="#F1F5F9" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="7+"
                android:textColor="@color/textSecondary"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Level 4: 14+ hari -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_level_4"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="🏆"
                android:textSize="18sp"
                android:background="@drawable/bg_stat_item"
                android:backgroundTint="#F1F5F9" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="14+"
                android:textColor="@color/textSecondary"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_streak_close"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Lanjutkan"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:cornerRadius="16dp"
        app:backgroundTint="@color/primary" />

</LinearLayout>