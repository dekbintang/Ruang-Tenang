<?xml version="1.0" encoding="utf-8"?>
<!--
    PERBAIKAN:
    - Ganti CoordinatorLayout → FrameLayout buat structure yang lebih simpel & predictable
    - Header menggunakan AppBarLayout + CollapsingToolbar sudah overkill; pakai LinearLayout biasa
    - ScrollView dipindahkan ke dalam NestedScrollView di bawah header (tidak lagi pakai marginTop manual)
    - Hapus layout_marginTop="-20dp" di CardView kalender (penyebab tumpang tindih)
    - Gunakan struktur LinearLayout vertikal sebagai root agar posisi header & konten tidak bertabrakan
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F7FE">

    <!-- ═══════════════════════════════════════════════════════
         HEADER — gradient bersih
         ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_calendar_header"
        android:orientation="vertical"
        android:paddingTop="28dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="28dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emotion Calendar"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.01" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Lacak perjalanan emosi harianmu 🌊"
            android:textColor="#BBDEFB"
            android:textSize="13sp"
            android:fontFamily="sans-serif" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════
         SCROLL KONTEN — di bawah header, tidak overlapping
         ═══════════════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Card Kalender — tidak ada marginTop negatif -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Navigasi bulan -->
                    <LinearLayout
                        android:id="@+id/layout_month_nav"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="20dp">

                        <ImageButton
                            android:id="@+id/btn_prev_month"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_nav_arrow"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_chevron_left"
                            android:padding="8dp"
                            app:tint="#1E3A8A" />

                        <TextView
                            android:id="@+id/tv_month_year"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Mei 2026"
                            android:textColor="#1e293b"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <ImageButton
                            android:id="@+id/btn_next_month"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_nav_arrow"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_chevron_right"
                            android:padding="8dp"
                            app:tint="#1E3A8A" />
                    </LinearLayout>

                    <!-- Header hari -->
                    <LinearLayout
                        android:id="@+id/layout_days_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <TextView style="@style/CalendarDayHeader" android:text="Sen" android:textColor="#1E3A8A" />
                        <TextView style="@style/CalendarDayHeader" android:text="Sel" android:textColor="#1E3A8A" />
                        <TextView style="@style/CalendarDayHeader" android:text="Rab" android:textColor="#1E3A8A" />
                        <TextView style="@style/CalendarDayHeader" android:text="Kam" android:textColor="#1E3A8A" />
                        <TextView style="@style/CalendarDayHeader" android:text="Jum" android:textColor="#1E3A8A" />
                        <TextView style="@style/CalendarDayHeader" android:text="Sab" android:textColor="#E05959" />
                        <TextView style="@style/CalendarDayHeader" android:text="Min" android:textColor="#E05959" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F1F5F9"
                        android:layout_marginBottom="4dp" />

                    <!-- Grid kalender -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_calendar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Legenda Mood -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <View
                            android:layout_width="4dp"
                            android:layout_height="18dp"
                            android:background="#1E3A8A"
                            android:layout_marginEnd="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Legenda Emosi"
                            android:textColor="#1e293b"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <!-- Baris 1 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😄" android:textSize="18sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="Senang" android:textColor="#64748b" android:textSize="12sp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍃" android:textSize="18sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="Tenang" android:textColor="#64748b" android:textSize="12sp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😐" android:textSize="18sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="Netral" android:textColor="#64748b" android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Baris 2 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😢" android:textSize="18sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="Sedih" android:textColor="#64748b" android:textSize="12sp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😰" android:textSize="18sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="Cemas" android:textColor="#64748b" android:textSize="12sp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😡" android:textSize="18sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="Marah" android:textColor="#64748b" android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Baris 3 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😳" android:textSize="18sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="Malu" android:textColor="#64748b" android:textSize="12sp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😱" android:textSize="18sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="Takut" android:textColor="#64748b" android:textSize="12sp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🥱" android:textSize="18sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="Malas" android:textColor="#64748b" android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="💡 Tap hari yang ada mood untuk membaca jurnal"
                android:textColor="#94A3B8"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>