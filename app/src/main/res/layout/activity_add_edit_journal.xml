<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:titleTextColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_chevron_left"
                app:tint="#FFFFFF"
                android:contentDescription="Kembali" />

            <TextView
                android:id="@+id/tv_toolbar_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Diary Baru"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_journal_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hari ini"
                android:textColor="#666666"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- Mood Selector -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perasaanku saat ini:"
                android:textColor="#333333"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <!-- Happy -->
                    <ImageButton
                        android:id="@+id/btn_mood_happy"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_mood_happy"
                        android:background="@drawable/bg_mood_happy"
                        android:layout_marginEnd="8dp"
                        app:tint="#FFFFFF"
                        android:padding="12dp" />

                    <!-- Calm -->
                    <ImageButton
                        android:id="@+id/btn_mood_calm"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_mood_calm"
                        android:background="@drawable/bg_mood_calm"
                        android:layout_marginEnd="8dp"
                        app:tint="#FFFFFF"
                        android:padding="12dp" />

                    <!-- Neutral -->
                    <ImageButton
                        android:id="@+id/btn_mood_neutral"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_mood_neutral"
                        android:background="@drawable/bg_mood_neutral"
                        android:layout_marginEnd="8dp"
                        app:tint="#FFFFFF"
                        android:padding="12dp" />

                    <!-- Sad -->
                    <ImageButton
                        android:id="@+id/btn_mood_sad"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_mood_sad"
                        android:background="@drawable/bg_mood_sad"
                        android:layout_marginEnd="8dp"
                        app:tint="#FFFFFF"
                        android:padding="12dp" />

                    <!-- Anxious -->
                    <ImageButton
                        android:id="@+id/btn_mood_anxious"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_mood_anxious"
                        android:background="@drawable/bg_mood_anxious"
                        android:layout_marginEnd="8dp"
                        app:tint="#FFFFFF"
                        android:padding="12dp" />

                    <!-- Angry -->
                    <ImageButton
                        android:id="@+id/btn_mood_angry"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_mood_angry"
                        android:background="@drawable/bg_mood_angry"
                        android:layout_marginEnd="8dp"
                        app:tint="#FFFFFF"
                        android:padding="12dp" />

                    <!-- Shy -->
                    <ImageButton
                        android:id="@+id/btn_mood_shy"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_mood_shy"
                        android:background="@drawable/bg_mood_shy"
                        android:layout_marginEnd="8dp"
                        app:tint="#FFFFFF"
                        android:padding="12dp" />

                    <!-- Scared -->
                    <ImageButton
                        android:id="@+id/btn_mood_scared"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_mood_scared"
                        android:background="@drawable/bg_mood_scared"
                        android:layout_marginEnd="8dp"
                        app:tint="#FFFFFF"
                        android:padding="12dp" />

                    <!-- Lazy -->
                    <ImageButton
                        android:id="@+id/btn_mood_lazy"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_mood_lazy"
                        android:background="@drawable/bg_mood_lazy"
                        app:tint="#FFFFFF"
                        android:padding="12dp" />

                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tv_selected_mood_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Netral"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Title Input -->
            <EditText
                android:id="@+id/et_journal_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Judul Diary"
                android:inputType="textCapSentences"
                android:background="@android:drawable/edit_text"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Content Input -->
            <EditText
                android:id="@+id/et_journal_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ceritakan harimu..."
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="10"
                android:gravity="top|start"
                android:background="@android:drawable/edit_text"
                android:padding="12dp" />

            <TextView
                android:id="@+id/tv_char_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 karakter"
                android:gravity="end"
                android:textSize="12sp"
                android:textColor="#999999"
                android:layout_marginTop="4dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Save Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@android:color/white"
        android:elevation="8dp">

        <Button
            android:id="@+id/btn_save_journal"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Simpan Diary"
            android:backgroundTint="@color/primary"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
