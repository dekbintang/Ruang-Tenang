<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base gradient -->
    <item>
        <shape>
            <gradient
                android:angle="150"
                android:startColor="#1E3A8A"
                android:centerColor="#1E40AF"
                android:endColor="#4F46E5"
                android:type="linear" />
            <corners android:bottomLeftRadius="36dp" android:bottomRightRadius="36dp" />
        </shape>
    </item>
    <!-- Decorative oval top-right -->
    <item
        android:top="-80dp"
        android:right="-60dp">
        <shape android:shape="oval">
            <solid android:color="#14FFFFFF" />
            <size android:width="220dp" android:height="220dp" />
        </shape>
    </item>
    <!-- Decorative oval bottom-left -->
    <item
        android:bottom="-50dp"
        android:left="-50dp">
        <shape android:shape="oval">
            <solid android:color="#0CFFFFFF" />
            <size android:width="160dp" android:height="160dp" />
        </shape>
    </item>
</layer-list>
