<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Solid Dark Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/background" />
        </shape>
    </item>

    <!-- Glowing Orb 1 (Top Left) -->
    <item
        android:top="-100dp"
        android:bottom="300dp"
        android:left="-100dp"
        android:right="100dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="300dp"
                android:centerX="0.2"
                android:centerY="0.2"
                android:startColor="#336366F1"
                android:endColor="#006366F1" />
        </shape>
    </item>

    <!-- Glowing Orb 2 (Bottom Right) -->
    <item
        android:top="400dp"
        android:bottom="-150dp"
        android:left="150dp"
        android:right="-50dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:centerX="0.8"
                android:centerY="0.8"
                android:startColor="#20EC4899"
                android:endColor="#00EC4899" />
        </shape>
    </item>

    <!-- Glowing Orb 3 (Top Right Accent) -->
    <item
        android:top="50dp"
        android:bottom="500dp"
        android:left="200dp"
        android:right="-100dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="250dp"
                android:centerX="0.9"
                android:centerY="0.1"
                android:startColor="#258B5CF6"
                android:endColor="#008B5CF6" />
        </shape>
    </item>
</layer-list>
