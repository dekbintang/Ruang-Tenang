<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="150"
                android:startColor="#1E3A8A"
                android:centerColor="#2563EB"
                android:endColor="#4F46E5"
                android:type="linear" />
            <corners android:bottomLeftRadius="40dp" android:bottomRightRadius="40dp" />
        </shape>
    </item>
    <!-- Decorative oval top-right -->
    <item android:top="-90dp" android:right="-70dp">
        <shape android:shape="oval">
            <solid android:color="#12FFFFFF" />
            <size android:width="240dp" android:height="240dp" />
        </shape>
    </item>
    <!-- Decorative oval bottom-left -->
    <item android:bottom="-60dp" android:left="-60dp">
        <shape android:shape="oval">
            <solid android:color="#0AFFFFFF" />
            <size android:width="180dp" android:height="180dp" />
        </shape>
    </item>
</layer-list>
