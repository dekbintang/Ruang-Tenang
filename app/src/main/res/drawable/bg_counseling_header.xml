<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base gradient — senada dengan dashboard & journal header -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#1E3A8A"
                android:centerColor="#1E40AF"
                android:endColor="#3B82F6"
                android:type="linear" />
            <corners android:bottomLeftRadius="36dp" android:bottomRightRadius="36dp" />
        </shape>
    </item>
    <!-- Decorative oval top-right -->
    <item
        android:top="-70dp"
        android:right="-50dp">
        <shape android:shape="oval">
            <solid android:color="#12FFFFFF" />
            <size android:width="210dp" android:height="210dp" />
        </shape>
    </item>
    <!-- Decorative oval bottom-left -->
    <item
        android:bottom="-40dp"
        android:left="-40dp">
        <shape android:shape="oval">
            <solid android:color="#0AFFFFFF" />
            <size android:width="150dp" android:height="150dp" />
        </shape>
    </item>
</layer-list>
